<div id="mobile-menu" class="hidden fixed top-14 left-0 right-0 z-99 bg-brown/95 backdrop-blur-(--blur-lg) flex-col items-center gap-5 py-8 px-5">
  <a href="#que-es" class="text-cream no-underline text-[16px] font-600 tracking-[0.1em] uppercase opacity-80 hover:opacity-100 transition-opacity">El Evento</a>
  <a href="#actividades" class="text-cream no-underline text-[16px] font-600 tracking-[0.1em] uppercase opacity-80 hover:opacity-100 transition-opacity">Actividades</a>
